# Database connection string (e.g., from Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/healthcare"

# NextAuth secret for JWT encryption (generate with `openssl rand -base64 32`)
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Gemini API Key for AI Summaries
GEMINI_API_KEY="your-gemini-key"

# SMTP Credentials for Email Notifications (e.g., Resend, Gmail App Password)
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="your-resend-api-key"

# Optional: Google Calendar API Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Secret for protecting Cron Job execution
CRON_SECRET="your-secure-cron-secret"
